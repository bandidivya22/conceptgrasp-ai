# ConceptGrasp AI - Root Environment Variables
# Copy this file to server/.env and client/.env as needed

# ===== SERVER =====
# See server/.env.example for full server config
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/conceptgrasp
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d
GEMINI_API_KEY=your_gemini_api_key_here
CLIENT_URL=http://localhost:5173

# ===== CLIENT =====
VITE_API_URL=/api
